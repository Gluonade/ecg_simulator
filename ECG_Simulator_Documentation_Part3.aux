\@writefile{lof}{\contentsline {figure}{\numberline {2.2}{\ignorespaces Main simulation loop call graph for Phase 3 engine. Each frame ($\sim $2 ms), \texttt  {step} is called, which advances the cable via 20 micro-steps and computes the ECG dipole.}}{12}{figure.caption.36}\protected@file@percent }
\newlabel{fig:call_graph}{{2.2}{12}{Main simulation loop call graph for Phase 3 engine. Each frame ($\sim $2 ms), \texttt {step} is called, which advances the cable via 20 micro-steps and computes the ECG dipole}{figure.caption.36}{}}
