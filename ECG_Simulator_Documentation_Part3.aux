\@writefile{lof}{\contentsline {figure}{\numberline {2.3}{\ignorespaces Data flow when user adjusts a parameter. The change propagates through the parameter model to the engine, which reinitializes and begins generating new ECG samples reflected in the display.}}{12}{figure.caption.37}\protected@file@percent }
\newlabel{fig:param_flow}{{2.3}{12}{Data flow when user adjusts a parameter. The change propagates through the parameter model to the engine, which reinitializes and begins generating new ECG samples reflected in the display}{figure.caption.37}{}}
