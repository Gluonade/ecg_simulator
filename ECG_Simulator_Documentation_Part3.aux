\@writefile{lof}{\contentsline {figure}{\numberline {2.4}{\ignorespaces Beat state machine for \texttt  {ConductionCableEngine}. A beat transitions from ``No Beat'' to ``In Progress'' when the SA node fires, then to ``Committed'' when all ventricular nodes have activated or a timeout is reached.}}{13}{figure.caption.38}\protected@file@percent }
\newlabel{fig:beat_state}{{2.4}{13}{Beat state machine for \texttt {ConductionCableEngine}. A beat transitions from ``No Beat'' to ``In Progress'' when the SA node fires, then to ``Committed'' when all ventricular nodes have activated or a timeout is reached}{figure.caption.38}{}}
